@echo off
:menu
title Raw Assembler
color 1f
mode con: cols=80 lines=25
cls
echo ================================================================================
echo ================================Raw Assembler===================================
echo =1. Compile File================================================================
echo =2. Exit========================================================================
echo ================================================================================
choice /c 12 /n /m "Input: "
if errorlevel 2 goto exit
if errorlevel 1 goto compilemenu1
:compilemenu1
cls
set /p file=Which File (Or Path2File) (Without Extensions): 
if not exist "%file%.asm" (
echo %file% Doesnt Exist.
pause
goto menu
)
cls
echo ================================================================================
echo ==============================Now Compiling...==================================
echo ================================================================================
nasm "%file%.asm" -f bin -o "%file%.bin"
if errorlevel 1 goto fail
goto success
:fail
color 4f
cls
echo ================================================================================
echo ==============================Compile Failed====================================
echo ================================================================================
pause
goto exit
:success
color 2f
cls
echo ================================================================================
echo ==============================Compile Succeded==================================
echo ================================================================================
pause
goto exit
:exit
exit
